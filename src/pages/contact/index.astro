---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";
import { contactData } from "../../config/contact";
---

<BaseLayout title="Contact | FO Com Supports Banque Postale">
  <Header />
  <main class="section">
    <div class="container contact-grid">
      <section class="contact-card">
        <p class="eyebrow">Contact</p>
        <h1>Joindre la section FO Com Supports Banque Postale</h1>
        <p>
          Pour une question individuelle, un signalement sur les conditions de travail ou une demande de rendez-vous,
          utilisez les coordonnees ci-dessous.
        </p>

        <ul class="contact-list">
          <li><strong>Email :</strong> {contactData.email}</li>
          <li><strong>Permanence :</strong> {contactData.permanence}</li>
          <li><strong>Site :</strong> {contactData.lieu}</li>
        </ul>
      </section>

      <section class="contact-card contact-card-alt">
        <p class="eyebrow">Representants</p>
        <ul class="contact-list">
          {contactData.representants.map((r) => (
            <li><strong>{r.role} :</strong> {r.nom}</li>
          ))}
        </ul>
        <p>
          {contactData.messageRelais}
        </p>
      </section>
    </div>
  </main>
  <Footer />
</BaseLayout>
