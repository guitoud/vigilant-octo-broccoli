---
import { formatDate } from "../utils/format";
import { resolvePostImage } from "../utils/images";

interface Props {
  post: {
    id: string;
    data: {
      title: string;
      date: Date;
      image: string;
      category: string;
    };
    body?: string;
  };
}

const { post } = Astro.props;
const slug = post.id.replace(/\.md$/, "");
const imageSrc = resolvePostImage(slug, post.data.image);
---

<article class="post-card">
  <a href={`/actualites/${slug}/`} class="post-card-image">
    <img src={imageSrc} alt={post.data.title} loading="lazy" />
  </a>

  <div class="post-card-body">
    <p class="post-meta">
      <span>{post.data.category}</span>
      <span>{formatDate(post.data.date)}</span>
    </p>
    <h2><a href={`/actualites/${slug}/`}>{post.data.title}</a></h2>
    <p>{post.body?.slice(0, 150).replace(/\n+/g, " ")}...</p>
    <a class="text-link" href={`/actualites/${slug}/`}>Lire l'article</a>
  </div>
</article>
